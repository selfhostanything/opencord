{
  "type": "module",
  "name": "@opencord/api-client",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "generate:openapi": "openapi-typescript ${OPENAPI_SPEC_PATH:-../../../opencord-server/openapi/openapi.yaml} -o src/generated/openapi.ts",
    "check:openapi": "pnpm generate:openapi && test -s src/generated/openapi.ts && git diff --exit-code -- src/generated/openapi.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  }
}
